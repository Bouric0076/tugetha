rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — can only read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;

      // Transactions — only the owner can read/write
      match /transactions/{txId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Groups — members can read, creator can write
    match /groups/{groupId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members;

      // Goals — group members can read/write
      match /goals/{goalId} {
        allow read, write: if request.auth != null;

        // Contributions
        match /contributions/{contribId} {
          allow read, write: if request.auth != null;
        }
      }
    }

    // Loans — borrower or lender can read/write
    match /loans/{loanId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.borrowerId
                      || request.auth.uid == resource.data.lenderId);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.borrowerId
                        || request.auth.uid == resource.data.lenderId);
    }

    // Paystack transactions — read only for verification
    match /paystack_transactions/{ref} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions can write
    }
  }
}
